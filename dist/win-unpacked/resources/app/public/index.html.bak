<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bot Multi-Browser Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { background: #0f172a; color: #f8fafc; font-family: 'Inter', sans-serif; }
        .glass-panel { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .tab-btn.active { border-bottom: 2px solid #38bdf8; color: #38bdf8; }
    </style>
</head>
<body class="min-h-screen flex flex-col p-4 md:p-6 bg-[#0f172a]">
    
    <!-- Header Navigation Menu -->
    <header class="w-full max-w-7xl mx-auto glass-panel rounded-2xl px-6 py-4 mb-6 shadow-xl flex items-center justify-between">
        <div class="flex items-center">
            <span class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">
                Multi-Browser Pro
            </span>
        </div>
        <nav class="hidden lg:flex space-x-6">
            <a href="#" id="menuBot" class="text-cyan-400 font-bold border-b-2 border-cyan-400 pb-1 transition">Bot YouTube</a>
            <a href="#" class="text-gray-400 font-bold pb-1 hover:text-pink-500 hover:border-b-2 hover:border-pink-500 transition">Bot Instagram</a>
            <a href="#" class="text-gray-400 font-bold pb-1 hover:text-white hover:border-b-2 hover:border-white transition">Bot TikTok</a>
            <a href="#" class="text-gray-400 font-bold pb-1 hover:text-green-400 hover:border-b-2 hover:border-green-400 transition">Bot Spotify</a>
            <a href="#" class="text-gray-400 font-bold pb-1 hover:text-blue-300 hover:border-b-2 hover:border-blue-300 transition">Bot TIDAL</a>
            <a href="#" class="text-gray-400 font-bold pb-1 hover:text-green-500 hover:border-b-2 hover:border-green-500 transition">Bot Rumble</a>
            <a href="#" id="menuFinder" class="text-purple-400 font-bold pb-1 hover:text-purple-300 hover:border-b-2 hover:border-purple-300 transition">🔍 Pencari Proxy</a>
        </nav>
        <!-- Mobile menu hint -->
        <div class="lg:hidden text-gray-400 text-sm font-bold">Menu</div>
    </header>

    <!-- VIEW 1: BOT DASHBOARD -->
    <div id="viewBot" class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 flex-grow">
        <!-- Kolom Kontrol Dashboard -->
        <div class="lg:col-span-4 glass-panel rounded-2xl p-6 shadow-2xl relative overflow-hidden max-h-[90vh] overflow-y-auto scrollbar-hide">
            <h1 class="text-3xl font-extrabold mb-6 text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 flex items-center">
                Bot Dashboard 🤖
            </h1>
            
            <!-- Statistics -->
            <div class="flex justify-between mb-6 p-4 bg-gray-800 rounded-lg border border-gray-700">
                <div class="text-center w-1/2 border-r border-gray-700">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Proxy Sukses</p>
                    <p class="text-3xl font-bold text-green-400" id="statSuccess">0</p>
                </div>
                <div class="text-center w-1/2">
                    <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Proxy Gagal</p>
                    <p class="text-3xl font-bold text-red-400" id="statFailed">0</p>
                </div>
            </div>

            <form id="botForm" class="space-y-5">
                <div class="flex items-center space-x-3 mb-2 p-3 bg-gray-800 rounded-lg border border-gray-700">
                    <input type="checkbox" id="checkWhoer" checked class="w-5 h-5 text-cyan-500 bg-gray-900 border-gray-700 rounded focus:ring-cyan-500 focus:ring-2 cursor-pointer">
                    <label for="checkWhoer" class="text-sm font-semibold text-gray-300 cursor-pointer">Tahap 0: Periksa Kualitas IP (Whoer.net)</label>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Tahap 1: Video Rekomendasi/Pancingan (Opsional)</label>
                    <div class="flex gap-2">
                        <input type="url" id="recoUrl" placeholder="https://youtube.com/watch?v=..."
                            class="w-2/3 bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                        <input type="number" id="recoDuration" value="60" min="10" placeholder="Detik"
                            class="w-1/3 bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                    </div>
                </div>

                <hr class="border-gray-700 my-4">

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Sumber Traffic (Target Utama)</label>
                    <select id="trafficSource" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm mb-4">
                        <option value="direct">Direct (Buka URL Video Langsung)</option>
                        <option value="search">Pencarian (Cari Kata Kunci ➔ Klik ID Video)</option>
                    </select>
                </div>

                <div id="directInputGroup">
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Tahap 2: Video Target (URL Langsung)</label>
                    <input type="url" id="videoUrl" placeholder="https://youtube.com/watch?v=..."
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                </div>

                <div id="searchInputGroup" class="hidden space-y-3">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-300">Tahap 2: Kata Kunci Pencarian</label>
                        <input type="text" id="searchKeyword" placeholder="Contoh: Lagu pop terbaru 2024"
                            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-300">Target Video ID</label>
                        <input type="text" id="searchVideoId" placeholder="Contoh: KDdSffsyDEA"
                            class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                        <p class="text-xs text-gray-500 italic mt-1">Bot akan mencari video dengan ID ini di hasil pencarian dan mengkliknya.</p>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Durasi Nonton Target (Detik)</label>
                    <input type="number" id="watchDuration" value="120" min="10" required
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                </div>

                <hr class="border-gray-700 my-4">

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Tahap 3: Video Random Lainnya (Opsional)</label>
                    <input type="url" id="randomVideoUrl" placeholder="https://youtube.com/watch?v=... (kosongkan = auto klik rekomendasi)"
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                    <p class="text-xs text-gray-500 italic mt-1">Jika dikosongkan, bot otomatis mengklik 1 video rekomendasi yang muncul di halaman.</p>
                </div>

                <hr class="border-gray-700 my-4">

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Proxy List (Daftar Antrean)</label>
                    <p class="text-xs text-gray-400 italic mb-2">Opsional. Kosongkan jika ingin menjalankan bot menggunakan IP asli Anda.</p>
                    <textarea id="proxyFile" rows="4" placeholder="Kosongkan untuk tanpa proxy, atau contoh:&#10;192.168.1.1:8080"
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all font-mono text-sm leading-relaxed"></textarea>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Tampilan Bot</label>
                    <select id="headlessMode" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                        <option value="false">Terlihat (Tampil di Layar)</option>
                        <option value="true">Siluman (Background)</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Jumlah Browser Serentak (Worker)</label>
                    <input type="number" id="browserCount" value="10" min="1" max="100" required
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Mode User Agent</label>
                    <select id="userAgentMode" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm">
                        <option value="all">🔀 Semua (Desktop & Mobile Acak)</option>
                        <option value="desktop">🖥️ Desktop Saja</option>
                        <option value="mobile">📱 Mobile Saja</option>
                    </select>
                    <p class="text-xs text-gray-500 italic mt-1">User agent dipilih acak dari ratusan variasi OS & versi browser.</p>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">⏱️ Jeda Antar Tab Browser (Detik)</label>
                    <input type="number" id="tabDelay" value="5" min="1" max="60" required
                        class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-sm">
                    <p class="text-xs text-gray-500 italic mt-1">Waktu tunggu sebelum membuka tab browser berikutnya. Nilai lebih besar = lebih stabil tapi lebih lama. Disarankan 3–10 detik.</p>
                </div>

                <div class="flex items-center space-x-3 mt-4 p-3 bg-gray-800 rounded-lg border border-gray-700">
                    <input type="checkbox" id="repeatBot" class="w-5 h-5 text-cyan-500 bg-gray-900 border-gray-700 rounded focus:ring-cyan-500 focus:ring-2 cursor-pointer">
                    <label for="repeatBot" class="text-sm font-semibold text-gray-300 cursor-pointer">🔄 Repeat Bot (Jalankan terus menerus tanpa henti pada proxy yang sama dengan UA berbeda)</label>
                </div>


                <div class="flex space-x-3 mt-8 pb-4">
                    <button type="submit" id="startBtn" 
                        class="w-2/3 bg-gradient-to-r from-cyan-600 to-blue-600 hover:from-cyan-500 hover:to-blue-500 text-white font-bold py-3 px-4 rounded-xl shadow-lg transform transition hover:-translate-y-1 active:scale-95 text-md">
                        ▶ Mulai Bot
                    </button>
                    <button type="button" id="stopBtn" disabled
                        class="w-1/3 bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-white font-bold py-3 px-4 rounded-xl shadow-lg transform transition hover:-translate-y-1 active:scale-95 text-md opacity-50 cursor-not-allowed">
                        🛑 Stop
                    </button>
                </div>
            </form>
        </div>

        <!-- Kolom Live Terminal Monitor -->
        <div class="lg:col-span-8 glass-panel rounded-2xl p-6 shadow-2xl flex flex-col h-[90vh]">

            <!-- SYSTEM MONITOR BAR -->
            <div class="grid grid-cols-4 gap-2 mb-4 p-3 bg-gray-900 rounded-xl border border-gray-700">
                <div class="text-center">
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">CPU</p>
                    <div class="w-full bg-gray-700 rounded-full h-2 mb-1">
                        <div id="cpuBar" class="bg-cyan-500 h-2 rounded-full transition-all duration-500" style="width:0%"></div>
                    </div>
                    <p class="text-sm font-bold text-cyan-400" id="cpuVal">0%</p>
                </div>
                <div class="text-center">
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">RAM</p>
                    <div class="w-full bg-gray-700 rounded-full h-2 mb-1">
                        <div id="ramBar" class="bg-purple-500 h-2 rounded-full transition-all duration-500" style="width:0%"></div>
                    </div>
                    <p class="text-sm font-bold text-purple-400" id="ramVal">0%</p>
                </div>
                <div class="text-center flex flex-col justify-center items-center">
                    <p class="text-xs text-gray-500 font-bold uppercase tracking-wider mb-1">NETWORK</p>
                    <p class="text-xs font-bold text-yellow-400" id="netRx">↓ 0 KB/s</p>
                    <p class="text-xs font-bold text-orange-400" id="netTx">↑ 0 KB/s</p>
                </div>
                <div class="text-center flex justify-center items-center">
                    <div id="statusBadge" class="px-4 py-2 text-sm font-bold rounded-full bg-gray-700 text-gray-300 shadow-inner flex items-center transition-colors">
                        <span class="w-3 h-3 rounded-full bg-gray-400 mr-2"></span> IDLE
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between mb-4 border-b border-gray-700 pb-2">
                <div class="flex space-x-6">
                    <button id="tabLogs" class="tab-btn active pb-2 text-gray-400 font-bold hover:text-white transition cursor-pointer flex items-center">
                        📄 Live Logs
                    </button>
                    <button id="tabSuccess" class="tab-btn pb-2 text-gray-400 font-bold hover:text-green-400 transition cursor-pointer flex items-center">
                        ✅ Sukses
                    </button>
                    <button id="tabFailed" class="tab-btn pb-2 text-gray-400 font-bold hover:text-red-400 transition cursor-pointer flex items-center">
                        ☠️ Gagal
                    </button>
                    <button id="tabAll" class="tab-btn pb-2 text-gray-400 font-bold hover:text-yellow-400 transition cursor-pointer flex items-center">
                        📊 Log Semua
                    </button>
                    <button id="tabActiveBots" class="tab-btn pb-2 text-gray-400 font-bold hover:text-cyan-400 transition cursor-pointer flex items-center">
                        🌐 Bot Aktif
                    </button>
                </div>
                <div class="flex space-x-4">
                    <button id="clearDataBtn" class="bg-red-900 hover:bg-red-700 text-red-200 text-xs px-3 py-1 rounded border border-red-700 transition">
                        🗑️ Clear Proxy Data
                    </button>
                </div>
            </div>
            
            <div id="logsContainer" class="flex-grow bg-[#0d1117] rounded-xl p-5 overflow-y-auto font-mono text-sm leading-relaxed border border-gray-800 shadow-inner relative">
                <!-- Tab Logs -->
                <div id="logs" class="text-green-400 absolute inset-x-5 top-5 bottom-5 overflow-y-auto scrollbar-hide space-y-1">
                    <span class="text-gray-500 italic">Menunggu perintah...</span>
                </div>
                <!-- Tab Success IPs -->
                <div id="successLogs" class="text-green-300 absolute inset-x-5 top-5 bottom-5 overflow-y-auto scrollbar-hide space-y-1 hidden">
                    <span class="text-gray-500 italic">Belum ada proxy yang sukses.</span>
                </div>
                <!-- Tab Failed IPs -->
                <div id="failedLogs" class="text-red-400 absolute inset-x-5 top-5 bottom-5 overflow-y-auto scrollbar-hide space-y-1 hidden">
                    <span class="text-gray-500 italic">Belum ada proxy yang gagal.</span>
                </div>
                <!-- Tab Log Semua -->
                <div id="allLogs" class="absolute inset-x-5 top-5 bottom-5 overflow-y-auto scrollbar-hide hidden">
                    <div class="grid grid-cols-3 gap-4 mb-4">
                        <div class="bg-gray-800 rounded-xl p-4 text-center border border-gray-700">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Total Video Diputar</p>
                            <p class="text-4xl font-extrabold text-yellow-400 mt-1" id="statVideoTotal">0</p>
                        </div>
                        <div class="bg-gray-800 rounded-xl p-4 text-center border border-gray-700">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Video Sukses</p>
                            <p class="text-4xl font-extrabold text-green-400 mt-1" id="statVideoSuccess">0</p>
                        </div>
                        <div class="bg-gray-800 rounded-xl p-4 text-center border border-gray-700">
                            <p class="text-xs text-gray-400 font-bold uppercase tracking-wider">Video Gagal / Error</p>
                            <p class="text-4xl font-extrabold text-red-400 mt-1" id="statVideoFailed">0</p>
                        </div>
                    </div>
                    <div class="mt-2 p-3 bg-gray-900 rounded-lg border border-gray-800">
                        <p class="text-xs text-gray-500 text-center italic">Statistik video diperbarui secara real-time saat bot berjalan.</p>
                    </div>
                </div>
                <!-- Tab Bot Aktif -->
                <div id="activeBotsLogs" class="absolute inset-x-5 top-5 bottom-5 overflow-y-auto scrollbar-hide space-y-2 hidden">
                    <span class="text-gray-500 italic">Belum ada bot yang aktif.</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Screenshot Modal -->
    <div id="screenshotModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-80 hidden backdrop-blur-sm transition-all duration-300">
        <div class="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl overflow-hidden max-w-4xl w-full mx-4 flex flex-col">
            <div class="flex justify-between items-center p-4 bg-gray-800 border-b border-gray-700">
                <h3 class="text-lg font-bold text-cyan-400" id="screenshotTitle">View Bot</h3>
                <button id="closeScreenshotBtn" class="text-gray-400 hover:text-red-400 transition text-2xl font-bold">
                    &times;
                </button>
            </div>
            <div class="p-4 flex justify-center bg-black relative">
                <p id="screenshotLoading" class="absolute text-cyan-400 font-bold italic z-0 mt-20 hidden">📸 Memuat Layar...</p>
                <img id="screenshotImg" src="" class="max-w-full max-h-[70vh] object-contain rounded z-10" alt="Bot Screenshot" />
            </div>
        </div>
    </div>

    <!-- VIEW 2: PROXY FINDER -->
    <div id="viewFinder" class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6 flex-grow hidden">
        <div class="lg:col-span-4 glass-panel rounded-2xl p-6 shadow-2xl relative">
            <h1 class="text-2xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500">
                🔍 Proxy Finder
            </h1>
            <p class="text-sm text-gray-400 mb-6">Mencari dan memvalidasi proxy publik secara otomatis.</p>
            <form id="finderForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Tipe Proxy</label>
                    <select id="proxyType" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white">
                        <option value="datacenter">Webserver (Datacenter) - Cepat</option>
                        <option value="residential">Residential - Aman</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-300">Target Proxy Valid yg Dicari</label>
                    <input type="number" id="findCount" value="50" min="1" max="500" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white">
                </div>
                <div class="flex space-x-2 mt-4">
                    <button type="submit" id="btnFind" class="w-2/3 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 text-white font-bold py-2 rounded-xl transition shadow-lg">
                        Mulai Cari
                    </button>
                    <button type="button" id="btnStopFind" disabled class="w-1/3 bg-red-600 hover:bg-red-500 text-white font-bold py-2 rounded-xl transition opacity-50 cursor-not-allowed shadow-lg">
                        Stop
                    </button>
                </div>
            </form>
            <div class="mt-6 p-4 bg-gray-800 rounded-lg text-center border border-gray-700">
                <p class="text-sm text-gray-400 uppercase font-bold tracking-widest">Proxy Bagus (Valid)</p>
                <p class="text-4xl font-bold text-green-400 mt-2" id="goodProxyCount">0</p>
            </div>
            <button type="button" id="btnDownload" class="w-full mt-4 bg-green-600 hover:bg-green-500 text-white font-bold py-3 rounded-xl transition shadow-lg hidden">
                ⬇️ Download Proxy Bagus (.txt)
            </button>
        </div>

        <div class="lg:col-span-8 glass-panel rounded-2xl p-6 shadow-2xl flex flex-col h-[80vh]">
            <div class="flex items-center justify-between mb-4 border-b border-gray-700 pb-2">
                <h2 class="text-lg font-bold text-gray-300">Live Proxy Checker</h2>
                <div id="finderStatus" class="px-3 py-1 text-xs font-bold rounded-full bg-gray-700 text-gray-300">IDLE</div>
            </div>
            <div id="finderLogs" class="flex-grow bg-[#0d1117] rounded-xl p-5 overflow-y-auto font-mono text-sm leading-relaxed border border-gray-800 space-y-1">
                <span class="text-gray-500 italic">Menunggu perintah pencarian...</span>
            </div>
        </div>
    </div>

    <script>
        const socket = io();
        const logsEl = document.getElementById('logs');
        const successLogsEl = document.getElementById('successLogs');
        const failedLogsEl = document.getElementById('failedLogs');
        const form = document.getElementById('botForm');
        const startBtn = document.getElementById('startBtn');
        const stopBtn = document.getElementById('stopBtn');
        const clearDataBtn = document.getElementById('clearDataBtn');
        const statusBadge = document.getElementById('statusBadge');
        
        const tabLogs = document.getElementById('tabLogs');
        const tabSuccess = document.getElementById('tabSuccess');
        const tabFailed = document.getElementById('tabFailed');

        const viewBot = document.getElementById('viewBot');
        const viewFinder = document.getElementById('viewFinder');
        const menuBot = document.getElementById('menuBot');
        const menuFinder = document.getElementById('menuFinder');

        // Proxy Finder Elements
        const finderForm = document.getElementById('finderForm');
        const btnFind = document.getElementById('btnFind');
        const btnStopFind = document.getElementById('btnStopFind');
        const btnDownload = document.getElementById('btnDownload');
        const finderLogs = document.getElementById('finderLogs');
        const goodProxyCount = document.getElementById('goodProxyCount');
        const finderStatus = document.getElementById('finderStatus');
        
        let foundProxies = [];

        // View Navigation
        menuBot.addEventListener('click', () => {
            viewBot.classList.remove('hidden');
            viewFinder.classList.add('hidden');
            menuBot.classList.add('text-cyan-400', 'border-b-2', 'border-cyan-400');
            menuBot.classList.remove('text-gray-400');
            menuFinder.classList.remove('text-purple-400', 'border-b-2', 'border-purple-300');
            menuFinder.classList.add('text-purple-400');
        });

        menuFinder.addEventListener('click', () => {
            viewFinder.classList.remove('hidden');
            viewBot.classList.add('hidden');
            menuFinder.classList.add('text-purple-400', 'border-b-2', 'border-purple-300');
            menuFinder.classList.remove('text-gray-400');
            menuBot.classList.remove('text-cyan-400', 'border-b-2', 'border-cyan-400');
            menuBot.classList.add('text-gray-400');
        });

        // FITUR: Simpan dan Muat Pengaturan (Local Storage)
        const inputIds = ['recoUrl', 'recoDuration', 'videoUrl', 'watchDuration', 'proxyFile', 'headlessMode', 'browserCount', 'userAgentMode', 'tabDelay', 'randomVideoUrl', 'trafficSource', 'searchKeyword', 'searchVideoId'];
        const checkboxIds = ['checkWhoer', 'repeatBot'];

        window.addEventListener('DOMContentLoaded', () => {
            inputIds.forEach(id => {
                const saved = localStorage.getItem('bot_setting_' + id);
                if (saved !== null) {
                    document.getElementById(id).value = saved;
                }
            });
            checkboxIds.forEach(id => {
                const saved = localStorage.getItem('bot_setting_' + id);
                if (saved !== null) {
                    document.getElementById(id).checked = saved === 'true';
                }
            });
        });

        inputIds.forEach(id => {
            document.getElementById(id).addEventListener('input', (e) => {
                localStorage.setItem('bot_setting_' + id, e.target.value);
            });
        });
        checkboxIds.forEach(id => {
            document.getElementById(id).addEventListener('change', (e) => {
                localStorage.setItem('bot_setting_' + id, e.target.checked);
            });
        });

        // Toggle UI based on Traffic Source
        const trafficSourceEl = document.getElementById('trafficSource');
        const directInputGroup = document.getElementById('directInputGroup');
        const searchInputGroup = document.getElementById('searchInputGroup');

        function toggleTrafficUI() {
            if (trafficSourceEl.value === 'search') {
                directInputGroup.classList.add('hidden');
                searchInputGroup.classList.remove('hidden');
            } else {
                directInputGroup.classList.remove('hidden');
                searchInputGroup.classList.add('hidden');
            }
        }
        trafficSourceEl.addEventListener('change', toggleTrafficUI);
        // Panggil saat awal load agar UI menyesuaikan localStorage
        setTimeout(toggleTrafficUI, 100);

        // Tab Navigation
        function switchTab(activeBtn, activeEl) {
            [tabLogs, tabSuccess, tabFailed, tabAll, tabActiveBots].forEach(b => b.classList.remove('active', 'border-b-2', 'border-white', 'text-white'));
            [logsEl, successLogsEl, failedLogsEl, allLogsEl, activeBotsLogs].forEach(e => e.classList.add('hidden'));
            activeBtn.classList.add('active', 'border-b-2', 'border-white', 'text-white');
            activeEl.classList.remove('hidden');
        }

        // DOM references
        const tabAll = document.getElementById('tabAll');
        const tabActiveBots = document.getElementById('tabActiveBots');
        const allLogsEl = document.getElementById('allLogs');
        const activeBotsLogs = document.getElementById('activeBotsLogs');
        const statVideoTotal = document.getElementById('statVideoTotal');
        const statVideoSuccess = document.getElementById('statVideoSuccess');
        const statVideoFailed = document.getElementById('statVideoFailed');

        tabLogs.addEventListener('click', () => switchTab(tabLogs, logsEl));
        tabSuccess.addEventListener('click', () => switchTab(tabSuccess, successLogsEl));
        tabFailed.addEventListener('click', () => switchTab(tabFailed, failedLogsEl));
        tabAll.addEventListener('click', () => switchTab(tabAll, allLogsEl));
        tabActiveBots.addEventListener('click', () => switchTab(tabActiveBots, activeBotsLogs));

        // Clear Data
        clearDataBtn.addEventListener('click', () => {
            if (confirm('Anda yakin ingin mereset history Proxy Sukses dan Gagal? Proxy yang sudah terpakai akan bisa dipakai lagi.')) {
                socket.emit('clear-proxy-data');
            }
        });

        function appendLog(msg, container) {
            const time = new Date().toLocaleTimeString('id-ID', { hour12: false });
            const line = document.createElement('div');
            line.innerHTML = `<span class="text-gray-600">[${time}]</span> ${msg}`;
            container.appendChild(line);
            container.scrollTop = container.scrollHeight;
        }

        socket.on('init-proxies', (data) => {
            successLogsEl.innerHTML = '';
            failedLogsEl.innerHTML = '';
            if (data.success.length === 0) successLogsEl.innerHTML = '<span class="text-gray-500 italic">Belum ada proxy yang sukses.</span>';
            if (data.failed.length === 0) failedLogsEl.innerHTML = '<span class="text-gray-500 italic">Belum ada proxy yang gagal.</span>';
            
            data.success.forEach(p => appendLog(`✅ ${p}`, successLogsEl));
            data.failed.forEach(p => appendLog(`☠️ ${p}`, failedLogsEl));
        });

        socket.on('log', (msg) => {
            if (logsEl.innerHTML.includes('Menunggu perintah...')) logsEl.innerHTML = '';
            appendLog(msg, logsEl);
        });

        socket.on('proxy-success', (proxyStr) => {
            if (successLogsEl.innerHTML.includes('Belum ada proxy yang sukses')) successLogsEl.innerHTML = '';
            appendLog(`✅ Proxy Selesai: ${proxyStr}`, successLogsEl);
        });

        socket.on('proxy-failed', (data) => {
            if (failedLogsEl.innerHTML.includes('Belum ada proxy yang gagal')) failedLogsEl.innerHTML = '';
            appendLog(`☠️ ${data.proxy} ➔ ${data.reason}`, failedLogsEl);
        });

        socket.on('active-bots', (bots) => {
            if (bots.length === 0) {
                activeBotsLogs.innerHTML = '<span class="text-gray-500 italic">Belum ada bot yang aktif.</span>';
                return;
            }
            
            let html = '<div class="grid grid-cols-1 lg:grid-cols-2 gap-3">';
            bots.forEach(bot => {
                const uptime = Math.floor((Date.now() - bot.startTime) / 1000);
                html += `
                    <div class="bg-gray-800 border border-gray-600 rounded-lg p-3 flex justify-between items-center shadow">
                        <div class="overflow-hidden">
                            <div class="font-bold text-cyan-300 mb-1">${bot.id}</div>
                            <div class="text-xs text-gray-300 font-mono mb-1 truncate">Proxy: ${bot.proxy}</div>
                            <div class="text-[10px] text-yellow-400 truncate">Device: ${bot.device} | Uptime: ${uptime}s</div>
                        </div>
                        <div class="flex flex-col space-y-2 ml-2">
                            <button onclick="requestViewBot('${bot.id}')" class="bg-blue-600 hover:bg-blue-500 text-white text-xs px-3 py-1 rounded transition">👁️ View</button>
                            <button onclick="socket.emit('close-bot', '${bot.id}')" class="bg-red-600 hover:bg-red-500 text-white text-xs px-3 py-1 rounded transition">❌ Close</button>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            activeBotsLogs.innerHTML = html;
        });

        // Screenshot Logic
        const screenshotModal = document.getElementById('screenshotModal');
        const closeScreenshotBtn = document.getElementById('closeScreenshotBtn');
        const screenshotImg = document.getElementById('screenshotImg');
        const screenshotTitle = document.getElementById('screenshotTitle');
        const screenshotLoading = document.getElementById('screenshotLoading');

        // Override view function so we can show loading text before the image arrives
        window.requestViewBot = function(botId) {
            screenshotTitle.innerText = `Layar Saat Ini: ${botId}`;
            screenshotImg.src = '';
            screenshotLoading.classList.remove('hidden');
            screenshotModal.classList.remove('hidden');
            socket.emit('view-bot', botId);
        };

        closeScreenshotBtn.addEventListener('click', () => {
            screenshotModal.classList.add('hidden');
            screenshotImg.src = '';
        });

        socket.on('bot-screenshot', (data) => {
            screenshotLoading.classList.add('hidden');
            screenshotImg.src = data.image;
        });

        socket.on('stats', (stats) => {
            statSuccess.innerText = stats.success;
            statFailed.innerText = stats.failed;
        });

        socket.on('video-stats', (vs) => {
            statVideoTotal.innerText = vs.total;
            statVideoSuccess.innerText = vs.success;
            statVideoFailed.innerText = vs.failed;
        });

        socket.on('sys-stats', (s) => {
            document.getElementById('cpuVal').innerText = s.cpuLoad + '%';
            document.getElementById('cpuBar').style.width = Math.min(s.cpuLoad, 100) + '%';
            document.getElementById('cpuBar').className = `h-2 rounded-full transition-all duration-500 ${ s.cpuLoad > 80 ? 'bg-red-500' : s.cpuLoad > 60 ? 'bg-yellow-500' : 'bg-cyan-500' }`;

            document.getElementById('ramVal').innerText = s.memUsed + '%';
            document.getElementById('ramBar').style.width = Math.min(s.memUsed, 100) + '%';
            document.getElementById('ramBar').className = `h-2 rounded-full transition-all duration-500 ${ s.memUsed > 80 ? 'bg-red-500' : s.memUsed > 60 ? 'bg-yellow-500' : 'bg-purple-500' }`;

            document.getElementById('netRx').innerText = `↓ ${s.rxKb} KB/s`;
            document.getElementById('netTx').innerText = `↑ ${s.txKb} KB/s`;
        });

        socket.on('status', (status) => {
            if (status === 'stopped') {
                startBtn.disabled = false;
                startBtn.innerHTML = '▶ Mulai Bot';
                startBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                
                stopBtn.disabled = true;
                stopBtn.classList.add('opacity-50', 'cursor-not-allowed');
                stopBtn.innerHTML = '🛑 Stop';

                statusBadge.innerHTML = '<span class="w-3 h-3 rounded-full bg-gray-400 mr-2"></span> IDLE';
                statusBadge.className = 'px-4 py-2 text-sm font-bold rounded-full bg-gray-700 text-gray-300 shadow-inner flex items-center transition-colors';
            }
        });

        // ==========================
        // PROXY FINDER LOGIC
        // ==========================
        socket.on('finder-log', (msg) => {
            if (finderLogs.innerHTML.includes('Menunggu perintah')) finderLogs.innerHTML = '';
            appendLog(msg, finderLogs);
        });

        socket.on('proxy-found', (proxy) => {
            foundProxies.push(proxy);
            goodProxyCount.innerText = foundProxies.length;
            if (foundProxies.length > 0) {
                btnDownload.classList.remove('hidden');
            }
        });

        socket.on('finder-status', (status) => {
            finderStatus.innerText = status;
            if (status === 'IDLE') {
                btnFind.disabled = false;
                btnFind.classList.remove('opacity-50', 'cursor-not-allowed');
                btnStopFind.disabled = true;
                btnStopFind.classList.add('opacity-50', 'cursor-not-allowed');
                finderStatus.className = 'px-3 py-1 text-xs font-bold rounded-full bg-gray-700 text-gray-300';
            } else {
                btnFind.disabled = true;
                btnFind.classList.add('opacity-50', 'cursor-not-allowed');
                btnStopFind.disabled = false;
                btnStopFind.classList.remove('opacity-50', 'cursor-not-allowed');
                finderStatus.className = 'px-3 py-1 text-xs font-bold rounded-full bg-purple-600 text-white animate-pulse';
            }
        });

        finderForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            foundProxies = [];
            goodProxyCount.innerText = '0';
            btnDownload.classList.add('hidden');
            finderLogs.innerHTML = '';
            
            const payload = {
                type: document.getElementById('proxyType').value,
                count: parseInt(document.getElementById('findCount').value)
            };

            try {
                await fetch('/api/find-proxies', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
            } catch (err) {
                appendLog(`<span class="text-red-500 font-bold">Error: ${err.message}</span>`, finderLogs);
            }
        });

        btnStopFind.addEventListener('click', async () => {
            await fetch('/api/stop-finder', { method: 'POST' });
        });

        btnDownload.addEventListener('click', () => {
            if (foundProxies.length === 0) return;
            const blob = new Blob([foundProxies.join('\n')], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `proxy_bagus_${new Date().getTime()}.txt`;
            a.click();
            URL.revokeObjectURL(url);
        });

        // ==========================
        // BOT LOGIC
        // ==========================
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const config = {
                checkWhoer: document.getElementById('checkWhoer').checked,
                recoUrl: document.getElementById('recoUrl').value,
                recoDuration: parseInt(document.getElementById('recoDuration').value),
                trafficSource: document.getElementById('trafficSource').value,
                videoUrl: document.getElementById('videoUrl').value,
                searchKeyword: document.getElementById('searchKeyword').value,
                searchVideoId: document.getElementById('searchVideoId').value,
                proxyFile: document.getElementById('proxyFile').value,
                headless: document.getElementById('headlessMode').value === 'true',
                browserCount: parseInt(document.getElementById('browserCount').value),
                watchDuration: parseInt(document.getElementById('watchDuration').value),
                userAgentMode: document.getElementById('userAgentMode').value,
                tabDelay: parseInt(document.getElementById('tabDelay').value) || 5,
                randomVideoUrl: document.getElementById('randomVideoUrl').value,
                repeatBot: document.getElementById('repeatBot').checked
            };

            startBtn.disabled = true;
            startBtn.innerHTML = '⚙️ Berjalan...';
            startBtn.classList.add('opacity-50', 'cursor-not-allowed');
            
            stopBtn.disabled = false;
            stopBtn.classList.remove('opacity-50', 'cursor-not-allowed');

            statusBadge.innerHTML = '<span class="w-3 h-3 rounded-full bg-white mr-2 animate-ping"></span> RUNNING';
            statusBadge.className = 'px-4 py-2 text-sm font-bold rounded-full bg-cyan-600 text-white shadow-inner flex items-center animate-pulse';

            try {
                const res = await fetch('/api/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });
                
                const data = await res.json();
                if (!res.ok) {
                    appendLog(`<span class="text-red-500 font-bold">Error Server: ${data.error}</span>`, logsEl);
                    socket.emit('status', 'stopped'); 
                }
            } catch (err) {
                appendLog(`<span class="text-red-500 font-bold">Error Koneksi: ${err.message}</span>`, logsEl);
                socket.emit('status', 'stopped');
            }
        });

        stopBtn.addEventListener('click', async () => {
            stopBtn.disabled = true;
            stopBtn.innerHTML = '⏳ Tunggu...';
            try {
                await fetch('/api/stop', { method: 'POST' });
            } catch (err) {
                appendLog(`<span class="text-red-500 font-bold">Gagal menghentikan bot: ${err.message}</span>`, logsEl);
                stopBtn.disabled = false;
                stopBtn.innerHTML = '🛑 Stop';
            }
        });
    </script>
</body>
</html>
